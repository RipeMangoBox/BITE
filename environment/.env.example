# ResearchFlow local environment template.
# Create a repo-root `.env` only when you need local overrides.

# OpenAI-compatible analysis provider settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional MinerU local mode override. If `mineru` is already on PATH, this can
# stay empty. Verify with `mineru --help` or set this path.
MINERU_CLI_PATH=

# Analysis note language: zh or en.
ANALYSIS_LANGUAGE=zh
